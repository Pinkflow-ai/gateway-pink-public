{
  "name": "@gateway-pink/public",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Gateway.pink public gateway — route handlers, storage-policy, and the no-payload-logging guard test.",
  "main": "./dist/server.js",
  "bin": {
    "gateway-pink-mcp": "./dist/mcp/stdio.js"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --import tsx/esm src/server.ts",
    "build": "tsc",
    "openapi:generate": "tsx src/openapi/write.ts",
    "openapi:check": "npm run openapi:generate && git diff --exit-code -- openapi/gateway.openapi.json sdks/typescript/src/index.ts sdks/python/gateway_pink/client.py src/generated/gatewayClient.ts",
    "sdk:check": "npx tsc -p sdks/typescript/tsconfig.json --noEmit && python3 -c \"import ast,pathlib; ast.parse(pathlib.Path('sdks/python/gateway_pink/client.py').read_text())\"",
    "contract:check": "npm run openapi:check && npm run sdk:check",
    "mcp:start": "tsx src/mcp/stdio.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "8.20.0",
    "csv-parse": "6.1.0",
    "csv-stringify": "6.6.0",
    "fastify": "^5.2.1",
    "fastify-raw-body": "^5.0.0",
    "google-libphonenumber": "^3.2.44",
    "pg": "^8.22.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "qrcode": "1.5.4",
    "redis": "^5.12.1",
    "ua-parser-js": "1.0.37",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/google-libphonenumber": "^7.4.30",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "1.5.5",
    "@types/ua-parser-js": "^0.7.39",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
