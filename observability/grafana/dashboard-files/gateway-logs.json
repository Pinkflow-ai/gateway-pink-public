{
  "title": "Gateway request logs",
  "uid": "gateway-logs",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["gateway-pink"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests (last 5m)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"gateway\"} | json [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "req" }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Errors (last 5m)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"gateway\"} | json | level=~\"error|warn\" [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "req" }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Rate-limited (last 5m)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"gateway\"} | json | status=\"429\" [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "req" }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Error rate (last 5m)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"gateway\"} | json | status=~\"4..|5..\" [5m])) / sum(count_over_time({job=\"gateway\"} | json [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requests by endpoint",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (endpoint) (count_over_time({job=\"gateway\"} | json [1m]))",
          "refId": "A",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "req/min" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Status codes",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (status) (count_over_time({job=\"gateway\"} | json [1m]))",
          "refId": "A",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "req/min" }
      }
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Recent errors",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"gateway\"} | json | level=~\"error|warn\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true
      }
    }
  ]
}
