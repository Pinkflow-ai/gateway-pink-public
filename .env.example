# Copy to .env for local dev. None of these are secrets that prove identity in
# production — this is the dev-only gateway. Real key management lives in the
# private repo.

# HTTP port the gateway listens on.
PORT=3000

# Comma-separated bearer tokens the gateway accepts. Dev convenience only.
# The real key store (hashed keys in Postgres) is not part of this public repo.
GATEWAY_DEV_KEYS=gp_dev_local

# pino log level. In prod: "info". For tracing: "debug".
LOG_LEVEL=info

# Per-source-IP development rate limit, requests per minute. Even the free APIs
# are rate-limited; production replaces this with the shared per-key limiter.
RATE_LIMIT_PER_MINUTE=120

# Upstream call budget (ms) for data and paid APIs.
UPSTREAM_TIMEOUT_MS=5000

# User-Agent sent to upstream data sources. NOAA/NWS requires a identifying UA.
UPSTREAM_USER_AGENT=Gateway.pink-dev (gateway.pink)

# Browser origins allowed to call the gateway (comma-separated, exact match).
CORS_ORIGINS=https://gateway.pink,http://localhost:4321,http://127.0.0.1:4321

# Paid routes fail closed unless the development meter is explicitly enabled.
BILLING_MODE=off
DEV_CREDIT_BALANCE=0
PRICING_MANIFEST_PATH=./config/pricing.manifest.json

# Provider credentials. Leave blank unless exercising the matching paid route.
ABSTRACT_EMAIL_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SCREENSHOTONE_ACCESS_KEY=
OPENROUTER_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
