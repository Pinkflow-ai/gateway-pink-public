# Development defaults. Copy to .env locally; never commit real values.
RUNTIME_ENV=development
PORT=3000
LOG_LEVEL=info
AUTH_MODE=dev
BILLING_MODE=off
RATE_LIMIT_MODE=memory
GATEWAY_DEV_KEYS=
DEV_CREDIT_BALANCE=0
RATE_LIMIT_PER_MINUTE=120
UPSTREAM_TIMEOUT_MS=5000
UPSTREAM_USER_AGENT=Gateway.pink (https://gateway.pink)
DEPENDENCY_TIMEOUT_MS=2000
PRICING_MANIFEST_PATH=./config/pricing.manifest.json
CORS_ORIGINS=https://gateway.pink,http://localhost:4321,http://127.0.0.1:4321

# Required together for the fail-closed production runtime.
# RUNTIME_ENV=production
# AUTH_MODE=postgres
# BILLING_MODE=postgres
# RATE_LIMIT_MODE=redis
# DATABASE_URL=postgresql://user:password@host:5432/gateway
# DATABASE_POOL_MAX=10
# DATABASE_SSL=require
# REDIS_URL=rediss://user:password@host:6379
# GATEWAY_KEY_PEPPER=generate-at-least-32-random-characters

# Paid providers. Routes release reservations and charge zero when a provider
# is unconfigured or fails.
ABSTRACT_EMAIL_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SCREENSHOTONE_ACCESS_KEY=
OPENROUTER_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
